GEMMA_API_KEY=your_gemma_api_key_here
GEMMA_MODEL=gemma-4-26b-a4b-it
GEMMA_FALLBACK_MODELS=
GEMMA_MAX_RETRIES=2
GEMMA_RETRY_DELAY_MS=700
GEMMA_MAX_RETRY_DELAY_MS=5000
GEMMA_TIMEOUT_CIRCUIT_FAILURE_THRESHOLD=5
GEMMA_TIMEOUT_CIRCUIT_COOLDOWN_MS=60000
MAX_CONCURRENT_LESSON_REQUESTS=3
LESSON_FAILURE_ALERT_THRESHOLD=5
SSE_HEARTBEAT_INTERVAL_MS=15000
FRONTEND_ORIGIN=https://reallearn.vercel.app
PORT=10000
SERPER_API_KEY=your_serper_api_key_here

# Clerk Authentication (Production)
CLERK_FRONTEND_API=https://clerk.reallearn.site
CLERK_JWKS_URL=https://clerk.reallearn.site/.well-known/jwks.json
CLERK_API_URL=https://api.clerk.com
# Production Clerk Backend API secret key (sk_live_...). Required for Clerk
# Backend API calls. Never commit the real value — set it in your host's secrets.
CLERK_SECRET_KEY=sk_live_your_production_secret_key_here
# Optional networkless JWT verification key (PEM / SPKI). When set, tokens are
# verified locally without hitting the JWKS endpoint (JWKS stays as the fallback).
# Store as a single line with literal \n escapes.
CLERK_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAsy95RHH/IzoHutLq7vl2\n8uo2xU2IjCw8nA9QhFTk4+1aEAJHiSaUa8iLOh71BX1L2Y+CpQbv6en6yWlYw++l\n9jE6q5sp07b3zF81SpzxayqqXDh35+hBsF79koEW8a+lT7Vs0LMGLvb3rMuHHVVP\n5HBJ7KG2X+9eFtMDmFjlKc8wKXZif20M3m1Y1MxCDgIbvB2c7PKVS5BV+2+prb9W\nNOFYy92ut7nyJLbEYXyEXk7ijmN9u5KP9vKo0zCPyj5/UM6AsIbWUkMONRgb3T1s\neVCKk4fs3w/daUu/MCnHE2ftmojAEMyVHZOFlRkmzZ3CHrZESbg8xOmKE2g1ugo9\n2wIDAQAB\n-----END PUBLIC KEY-----"
