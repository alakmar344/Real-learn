# Cerebras Cloud — primary AI provider (Gemma 4 31B).
# Get an API key from https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Primary model ID (Cerebras).
GEMMA_MODEL=gemma-4-31b
# Extra Cerebras models to rotate to when the primary model 404s/throttles
# (comma-separated).
GEMMA_FALLBACK_MODELS=
GEMMA_MAX_RETRIES=1
GEMMA_RETRY_DELAY_MS=700
GEMMA_MAX_RETRY_DELAY_MS=5000
# Per-provider circuit breaker: after this many consecutive availability
# failures (timeout/429/5xx/network) the provider is skipped for the cooldown
# window and traffic routes straight to the other provider. Default 2 — a
# degraded provider times out on EVERY call, so trip early.
GEMMA_TIMEOUT_CIRCUIT_FAILURE_THRESHOLD=2
GEMMA_TIMEOUT_CIRCUIT_COOLDOWN_MS=60000

# Cloudflare Workers AI — fallback AI provider (Gemma).
# Create an API token with the "Workers AI" permission:
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
# First-choice Cloudflare fallback model (must be a fully qualified Workers AI
# model ID).
CLOUDFLARE_AI_MODEL=@cf/google/gemma-4-26b-a4b-it
# Rotation list: models get rate-limited or delisted without notice, so list
# several — on a 400/404/429 the engine advances to the next model and
# remembers the working one for future requests (comma-separated, in order).
CLOUDFLARE_AI_MODELS=@cf/google/gemma-4-9b-it-qa

# Hedged racing (COST-AWARE): the engine starts the healthiest provider first.
# If it has shown NO sign of life (zero bytes) after this many ms — or fails
# outright — the other provider launches IN PARALLEL and the first success
# wins. A provider that is alive and generating is NEVER hedged against, so
# Cloudflare fallback tokens are only spent on genuine rescues.
AI_HEDGE_DELAY_MS=12000

# Streaming silence watchdogs: responses stream, so a hung request is killed
# by SILENCE instead of burning the whole per-attempt timeout (a hang is
# detected in ~15-20s instead of 45s).
# First byte allowance (cold starts legitimately take 10-30s):
AI_FIRST_BYTE_TIMEOUT_MS=20000
# Max silence between stream chunks once generation has started:
AI_STALL_TIMEOUT_MS=15000

# Warm-up cost control: periodic warm-up pings only run while there was user
# activity within this window (default 15 min). Idle nights/weekends no longer
# burn ~960 warm-up calls/day; warm-up resumes automatically with traffic.
WARM_UP_IDLE_WINDOW_MS=900000
# GEMMA_WARM_UP_INTERVAL_MS=90000
MAX_CONCURRENT_LESSON_REQUESTS=3
LESSON_FAILURE_ALERT_THRESHOLD=5
SSE_HEARTBEAT_INTERVAL_MS=15000
FRONTEND_ORIGIN=https://reallearn.vercel.app
PORT=10000
SERPER_API_KEY=your_serper_api_key_here

# Turn off Gemma 4's hidden "thinking" tokens — they are stripped from the
# answer anyway but burn real generation tokens (often 30-50% of output).
# Default is now "cerebras" (primary provider) to cut per-request token spend.
#   AI_DISABLE_THINKING=off   # off (default) | cerebras | cloudflare | both
# Roll back to "off" if a provider 400s on the field.
AI_DISABLE_THINKING=cerebras

# MongoDB (either name works; MONGODB_URI takes precedence)
MONGODB_URI=your_mongodb_connection_string_here
# MONGODB_URL=your_mongodb_connection_string_here
MONGODB_DB=reallearn

# Clerk Authentication
# CLERK_FRONTEND_API is the token issuer (your Clerk "Frontend API URL").
# Defaults to https://clerk.reallearn.site in code; override here if needed.
CLERK_FRONTEND_API=https://clerk.reallearn.site
# Optional: defaults to <CLERK_FRONTEND_API>/.well-known/jwks.json
# CLERK_JWKS_URL=https://clerk.reallearn.site/.well-known/jwks.json
# Clerk Backend API URL (used by the Clerk SDK, not by JWT verification here)
CLERK_API_URL=https://api.clerk.com
# Clerk Backend API secret key — REQUIRED for DELETE /api/account (account deletion).
CLERK_SECRET_KEY=your_clerk_secret_key_here
# Offline verification fallback (PEM). Only used if the JWKS URL is unreachable.
# A default is baked into the code; set this to override. Use \n for newlines if
# your host doesn't support multi-line env values.
# CLERK_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Privacy: moderation logs (flagged question + reason, pseudonymous Clerk ID)
# auto-delete from MongoDB via a TTL index after this many days. Consent
# records ("agreements") are NOT affected — they are permanent until account
# deletion. Lessons/messages are already temporary (short-lived caches).
MODERATION_LOG_TTL_DAYS=90

# Rate limiting (per user token / per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Security: the /api/auth-debug endpoint is disabled in production unless
# this is explicitly set to true (it is an unauthenticated token oracle).
AUTH_DEBUG_ENABLED=false

# Optional: extra trusted Clerk token issuers (comma-separated). In production
# only the configured issuer, this allowlist, and *.reallearn.site are trusted.
# CLERK_ADDITIONAL_ISSUERS=https://your-instance.clerk.accounts.dev

# Optional (recommended in production): pin the token's authorized party (azp)
# to your frontend origin(s). Rejects valid tokens minted for OTHER apps that
# share the same Clerk instance. Comma-separated, no trailing slashes.
# CLERK_AUTHORIZED_PARTIES=https://reallearn.site,https://www.reallearn.site

# Privacy: salt used to hash User-Agent strings stored on consent records.
# MUST be stable across restarts/instances (a per-process random salt would
# make the same device hash differently after every deploy, defeating
# repeat-device fraud detection). If unset, a stable value is derived from
# other configuration.
# UA_HASH_SALT=some-long-random-string

# Legal document versions stamped onto consent records (defaults shown).
# PRIVACY_POLICY_VERSION=2.3
# TERMS_OF_SERVICE_VERSION=2.2
# COOKIE_POLICY_VERSION=2.1
