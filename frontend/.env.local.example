# Clerk Authentication (Production)
# Production publishable key for Frontend API https://clerk.reallearn.site
# (pk_live keys are public; the host is base64-encoded inside the key).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsucmVhbGxlYXJuLnNpdGUk
# Production secret key (sk_live_...). Required by Clerk server-side helpers and
# middleware. Never commit the real value — set it in your host's secrets.
CLERK_SECRET_KEY=sk_live_your_production_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
NEXT_PUBLIC_BACKEND_URL=https://real-learn.onrender.com
NEXT_PUBLIC_STREAM_IDLE_TIMEOUT_MS=120000
